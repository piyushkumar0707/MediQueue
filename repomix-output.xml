      ],
      "byType": [
        { "_id": "consultation", "count": 300 },
        { "_id": "follow-up", "count": 150 }
      ]
    },
    "queue": {
      "total": 380,
      "byPriority": [
        { "_id": "normal", "count": 250 },
        { "_id": "urgent", "count": 100 },
        { "_id": "emergency", "count": 30 }
      ],
