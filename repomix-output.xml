                        <div>
                          <div className="text-sm font-medium text-gray-900">
                            {access.doctor?.personalInfo?.firstName} {access.doctor?.personalInfo?.lastName}
                          </div>
                          <div className="text-sm text-gray-500">
                            {access.doctor?.email}
