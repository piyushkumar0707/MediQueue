const testDoctorQueue = async () => {
  try {
    await mongoose.connect(process.env.MONGODB_URI);
    console.log('✅ Connected to database\n');

    // Get Doctor 1
    const doctor = await User.findOne({ email: 'doctor1@gmail.com' });
    
