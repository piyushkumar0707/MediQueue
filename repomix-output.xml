                        >
                          View Patient Records
                        </button>
                        {appointment.status === 'scheduled' || appointment.status === 'confirmed' ? (
                          <button
                            onClick={() => navigate('/doctor/prescriptions/create', { state: { patientId: appointment.patient._id } })}
