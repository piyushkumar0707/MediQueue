# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/carequeue

# Redis (OTP storage with TTL)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this
JWT_REFRESH_EXPIRY=7d

# Email Configuration (NodeMailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@carequeue.com

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Cloudinary (Medical record file storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=your-session-secret-key-change-this

# Groq AI (LLaMA 3.1 + LLaMA 4 Scout vision) — get free key at console.groq.com
GROQ_API_KEY=your-groq-api-key

# AI Feature flags (set to 'false' to disable without a deploy)
# Text triage/summarization uses: llama-3.1-8b-instant
# Image analysis uses:            meta-llama/llama-4-scout-17b-16e-instruct
AI_FEATURE_TRIAGE=true
AI_FEATURE_SUMMARIZE=true
AI_FEATURE_IMAGE_ANALYSIS=true
